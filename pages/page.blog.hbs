                            "title": "Microneedling vs Botox"
                        }
                    ]'
                }}
                    <li>
                        {{> c-post-tile
                            image=image
                            tag=tag
                            date=date
                            read=read
                            title=title
                        }}
                    </li>
                {{/parseJson}}
            </ul>
            <div>
                <button type="button" disabled>{{> e-icon icon="chevron"}}</button>
                <div><strong>1</strong> / 12</div>
                <button type="button">{{> e-icon icon="chevron"}}</button>
            </div>
        </div>
        <div class="blog__top-list">
