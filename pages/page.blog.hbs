{{#> new
    title="Blog"
    body-class="page.blog"
}}

{{#> section-stack }}
    {{#> breadcrumb }}
        <a href="#">Home</a>
        {{> e-icon icon="chevron" }}
        <strong>All Posts</strong>
    {{/breadcrumb}}
    {{#> blog }}
        <div class="blog__sections">
            <h2>Choose your topic</h2>
            <ul>
                {{#parseJson
                    '[
                        {
                            "img": "choose_blog_1",
                            "name": "LED Light Therapy"
                        },
                        {
                            "img": "choose_blog_2",
                            "name": "Skin"
                        },
                        {
                            "img": "choose_blog_3",
                            "name": "Skincare"
                        }
                    ]'
                }}
                    <li>
                        <a href="#">
                            <picture>
                                <source media="(min-width:768px)" srcset="sections/isolated/blogs/images/{{ img }}.webp">
                                <img src="sections/isolated/blogs/images/{{ img }}_mob.webp" alt="{{ name }}">
                            </picture>
                            <h6>{{ name }}</h6>
                        </a>
                    </li>
                {{/parseJson}}
            </ul>
        </div>
        <div class="blog__posts">
            <h2>Articles</h2>
            <ul>
                {{#parseJson
                    '[
                        {
                            "image": "sections/isolated/blogs/images/article_1.webp",
                            "tag": "#all",
                            "date": "July 04, 2025",
                            "read": "6 min read",
