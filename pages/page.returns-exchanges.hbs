{{#> default
    title="Easy Returns & Exchanges"
    body-class="page.returns-exchanges"
}}

{{#> section-stack }}
    {{#> across-image-banner
        classes="across-image-banner--hero"
    }}
        <picture>
            <source media="(min-width: 768px)" srcset="sections/isolated/page-banner/images/return-hero.webp" />
            <img src="sections/isolated/page-banner/images/return-hero-mob.webp" />
        </picture>
        <div class="container">
            <article>
                <h1>Easy Returns &amp; Exchanges</h1>
                <p>Shop with confidence at Qure</p>
            </article>
        </div>
    {{/across-image-banner}}

    {{#> base-section
        classes="base-section--simple-grid"
        title="Simple Hassle-Free Returns"
        picture="sections/global/banner-with-text/images/hf-returns.webp"
    }}
        <p>At Qure, we want you to feel confident with your purchase. That’s why we offer easy returns and exchanges.</p>
        <h2>30-Day Money Back Guarantee</h2>
        <p>Changed your mind? Returns can be initiated within 30 days upon receiving your order to qualify for our money back guarantee.</p>
    {{/base-section }}

    {{#> base-section
        classes="base-section--simple-grid base-section--reverse"
        title="Our Return Policy"
        picture="sections/global/banner-with-text/images/hf-policy.webp"
    }}
        <p>Here’s the low-down on the terms and conditions that apply to the guarantee. You can read <a href="#">full T&amp;Cs here</a>.</p>
        <ul>
            <li>30 days to return OR exchange for a full refund.</li>
            <li>Returns first need to be approved by Qure support.</li>
            <li>Product must be new, unused with the seal intact.</li>
            <li>Shipping charges are non-refundable.</li>
            <li>A Restocking Fee of $10 will be deducted from the refund.</li>
        </ul>
    {{/base-section }}

    {{#> how-to-use
        classes="how-to-use--center how-to-use--bg"
        title="How to return or exchange"
    }}
        <div
            class="c-swiper"
            data-swiper='{
                "slidesPerView": 1.05,
                "spaceBetween": 16,
                "loop": false,
                "pagination": {
                    "el": ".c-swiper-pagination",
                    "type": "custom"
                },
                "navigation": {
                    "prevEl": ".c-swiper-button-prev",
                    "nextEl": ".c-swiper-button-next"
                },
                "breakpoints": {
                    "768": {
                        "slidesPerView": 4,
                        "spaceBetween": 32
                    }
                }
            }'
        >
            <div class="swiper-wrapper">
                <div class="swiper-slide">
                    <picture data-index="1">
                        <img src="sections/isolated/compliment-skin/images/5.webp" alt="Go to the returns portal" />
                    </picture>
                    <article>
                        <h6>Go to the returns portal</h6>
                        <p><a href="#">Click here to visit our returns &amp; exchanges portal page.</a> Enter your order number and either your shipping code or email address.</p>
                    </article>
                </div>
                <div class="swiper-slide">
                    <picture data-index="2">
                        <img src="sections/isolated/compliment-skin/images/6.webp" alt="Choose what’s next" />
                    </picture>
                    <article>
                        <h6>Choose what’s next</h6>
                        <p>Pick whether it’s a return or exchange and answer a few questions. You’ll be asked to provide a photo of the item(s). </p>
                    </article>
                </div>
                <div class="swiper-slide">
                    <picture data-index="3">
                        <img src="sections/isolated/compliment-skin/images/7.webp" alt="Get an RMA Number" />
                    </picture>
                    <article>
                        <h6>Get an RMA Number</h6>
                        <p>If approved, you will be provided the return instructions and a Return Merchandise Authorization (RMA) number from our team via email. This is required for all successful returns.</p>
                    </article>
                </div>
                <div class="swiper-slide">
                    <picture data-index="4">
                        <img src="sections/isolated/compliment-skin/images/8.webp" alt="Pack and ship" />
                    </picture>
                    <article>
                        <h6>Pack and ship</h6>
                        <p>Securely pack item(s) in a box and ship them! We encourage you to use a trackable shipping service. Please allow up to 7-14 business days for your return to be processed.</p>
                    </article>
                </div>
            </div>
            <div class="c-swiper-nav">
                <button class="c-swiper-button-prev"></button>
                <div class="c-swiper-pagination"></div>
                <button class="c-swiper-button-next"></button>
            </div>
        </div>
        <a class="btn btn--primary" href="#">Start A Return</a>
    {{/how-to-use }}

    {{#> contact-us
        title="Have questions?"
        hide-form=true
     }}
        <p>
            If you have a question about your order please contact our customer service team by sending an email to support@qureskincare.com. <br />
            For more information on our warranty please visit our warranty policy here.
        </p>
    {{/contact-us }}

    {{#> across-image-banner
        classes="across-image-banner--sm"
    }}
        <picture>
            <source media="(min-width: 768px)" srcset="sections/isolated/our-story-banner/images/feeling_good_banner.webp" />
            <img src="sections/isolated/our-story-banner/images/feeling_good_banner_mob.webp" />
        </picture>
        <div class="container">
            <article>
                <h2>Feeling good in your skin is so much more than skin deep. </h2>
            </article>
        </div>
    {{/across-image-banner }}

    {{> tiles-group
        title="More Help at Your Fingertips"
        list='[
            {
                "img": "sections/isolated/help-links/images/1.webp",
                "name": "Start Your Skin Consultation"
            },
            {
                "img": "sections/isolated/help-links/images/2.webp",
                "name": "Start Your Skin Consultation"
            },
            {
                "img": "sections/isolated/help-links/images/3.webp",
                "name": "Start Your Skin Consultation"
            }
        ]'
    }}

    {{> have-questions
        list='[
            {
                "summary": "I used a promo code on my purchase. Will I get a new code?",
                "text": "
                    <p>Orders placed with a promo code that discounts the order are only eligible for a store credit in a form of voucher(s).</p>
                "
            },
            {
                "summary": "What should I do if I received the wrong item?",
                "text": "
                    <p>If you received a product different from the one that you ordered, please contact us at support@qureskincare.com and we’ll be sure to make this right!</p>
                "
            },
            {
                "summary": "How long does it take to process my return?",
                "text": "
                    <p>Once your return package has arrived with us, please allow up to 7-14 business days for your return to be processed. Credit card refunds usually take 5-10 business days to appear on your statement.</p>
                "
            },
            {
                "summary": "Is there a restocking fee?",
                "text": "
                    <p>Yes, a return fee will be deducted from the refund to cover the warehouse cost to return the product. This fee amounts to $10 for all products. Customer service agents can provide a more exact cost if the returned product is subject to a shipping fee.</p>
                "
            }
        ]'
    }}
{{/section-stack }}

{{/default }}
