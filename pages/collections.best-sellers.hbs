{{#> new
    title="Best Sellers"
    body-class="collections.best-sellers"
}}

{{#> section-stack }}
    {{#> hero-banner
        classes="hero-banner--holidays"
    }}
        <picture>
            <source media="(min-width:768px)" srcset="sections/new/hero-banner/images/iwd.webp">
            <img src="sections/new/hero-banner/images/iwd-mob.webp" alt="">
        </picture>
        <div class="container">
            <article>
                <h2>Together, We Rise</h2>
                <p>This International Women’s Day $2 from every order will be donated to <strong>Impact for Women</strong> to help women rebuild their lives and regain confidence.</p>
            </article>
        </div>
    {{/hero-banner}}

    {{#> breadcrumb }}
        <a href="#">Home</a>
        {{> e-icon icon="chevron" }}
        <strong>Best Sellers</strong>
    {{/breadcrumb}}

    {{#> pills-nav
        classes="pills-nav--left"
    }}
        <div class="pills-nav__header">
            <span>Shop by</span>
            <div>Swipe for more <i class="e-icon e-icon-arrow"></i></div>
        </div>
        <ul class="c-pills-nav">
            <li><button data-url="" class="active">Shop All</button></li>
            <li><button data-url="">Fine Lines &amp; Wrinkles</button></li>
            <li><button data-url="">Dark Spots &amp; Hyperpigmentation</button></li>
            <li><button data-url="">Breakouts &amp; Acne</button></li>
        </ul>
    {{/pills-nav}}

    {{#> best-sellers }}
        <div class="best-sellers__item">
            <a class="best-sellers__review" href="#">
