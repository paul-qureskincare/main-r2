{{#> new
    title="Skincare Wrinkles"
    body-class="page.personalized-skin-care-plan"
}}

{{#> section-stack }}
    {{#> base-section
        title="[Name], your results are in."
        picture="sections/global/banner-with-text/images/transform_aging.webp"
        button="Shop & Save 25%"
    }}
        <h6>Let’s transform your signs of aging!</h6>
        <br />
        <p>We put together a straightforward, no-nonsense program just for you and your skin. It’s aimed to help you reduce the signs of aging, fine lines and wrinkles, keep your skin smooth, and your confidence high.</p>
    {{/base-section }}

    {{#> we-suggest
        title="Based on your goals, we suggest:"
    }}
        <div class="we-suggest__list">
            {{#> c-suggest-card
                title="Q-Rejuvalight Pro Facewear"
                image="sections/isolated/skincare-plan/images/q-rej-product.webp"
                image-hover="/sections/isolated/skincare-plan/images/hov_img_1.webp"
                results="sections/isolated/skincare-plan/images/transform_aging_97.webp"
                desc="A hands-free LED light therapy mask that uses clinically proven wavelengths to target multiple skin concerns."
                video="jwKN4SH4yz8"
                quot-strong="I noticed results straight away!"
                quot-small="Now I can’t go a day without the Q-Rejuvalight Mask."
                added=true
                id="suggestCardRejuvalight"
            }}
                <ul class="c-marked-list">
                    <li>FDA-cleared device designed to treat wrinkles and mild-to-moderate inflammatory acne.</li>
                    <li>Customizable treatment on 5 facial areas for your specific skin concerns.</li>
                    <li>Quick 3 minute, wireless daily treatments with convenient hands-free operation.</li>
                </ul>
            {{/c-suggest-card }}
            {{#> c-suggest-card
                title="Micro-Infusion 3 Month Bundle (For Wrinkles)"
                image="sections/isolated/skincare-plan/images/mi-prod.webp"
                image-hover="/sections/isolated/skincare-plan/images/hov_img_2.webp"
                results="sections/isolated/skincare-plan/images/mi-result.webp"
                desc="Inspired by in-clinic microneedling for results you can see and feel—with minimal to no downtime."
                video="JPWycy8cwN8"
                quot-strong="Even my esthetician is hooked!"
                quot-small="And I can now visit beauty clinics less often."
                id="suggestCardMi"
            }}
