                    <li>Smooths fine lines and softens wrinkles.</li>
                    <li>Improves tone and texture through gentle skin renewal and deep hydration</li>
                    <li>Clinically backed and easy to use at home</li>
                </ul>
            {{/c-suggest-card }}
            {{#> c-suggest-card
                title="All-In-One Face Serum"
                image="sections/isolated/skincare-plan/images/all-in-prod.webp"
                image-hover="/sections/isolated/skincare-plan/images/hov_img_3.webp"
                results="sections/isolated/skincare-plan/images/all_in_res_acne.webp"
                desc="A multi-tasking formula designed to hydrate, brighten, and strengthen skin barrier in one step."
                video="PJt57LcFEQk"
                quot-strong="This product is a keeper."
                quot-small="My skin looks better than ever after just 2 weeks."
                id="suggestCardSerum"
            }}
