                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
                <td>Show minimal improvement or change</td>
            </tr>
            <tr>
                <td>Penetrates deep for better results</td>
                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
                <td>Topical products stay on the surface</td>
            </tr>
            <tr>
                <td>Gentle on skin with no downtime</td>
                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
                <td>Can cause irritation and peeling</td>
            </tr>
            <tr>
                <td>Safe to use at-home</td>
                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
                <td>Often requires clinic visits and downtime</td>
            </tr>
            <tr>
                <td>Backed by dermatologists</td>
                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
