    {{> logos-marquee }}

    {{#> skincare-routine
        title="Meet your new skincare routine"
    }}
        <div class="skincare-routine__media">
            <div class="skincare-routine__media-item show">
                {{#> c-wistia-embed-video
                    classes=""
                    id="klt401yhji"
                    alt="Watch: Doctorly"
                    inline=true
                }}
                {{/c-wistia-embed-video}}
            </div>
            <div class="skincare-routine__media-item">
                <img src="sections/isolated/skincare-routine/images/weekly.webp" alt="Neck & Décolletage LED Device" />
            </div>
            <div class="skincare-routine__media-item">
                {{#> c-wistia-embed-video
                    classes=""
                    id="spbl22fho4"
                    alt="Watch: Doctorly"
                    inline=true
                }}
                {{/c-wistia-embed-video}}
            </div>
        </div>
        <ul class="skincare-routine__switcher">
            <li><button type="button" class="active">Daily</button></li>
            <li><button type="button">Weekly</button></li>
            <li><button type="button">Biweekly</button></li>
        </ul>
        <div class="skincare-routine__info">
            <div class="skincare-routine__info-item show">
                <h6>How To Use</h6>
                <p>Cleanse and dry your skin. Put on your Q-Rejuvalight Pro on the Skin Rejuvenating treatment mode for a full 3 minute session. Follow with the All-In-One Face Serum, applying to your face and neck.</p>
                <hr />
                <h6>When To Use</h6>
                <div class="badges">
                    <div class="e-pill-badge e-pill-badge--sm">
                        <i class="e-icon e-icon-am"></i> AM
                    </div>
                    <span>or</span>
                    <div class="e-pill-badge e-pill-badge--sm">
                        <i class="e-icon e-icon-pm"></i> PM
                    </div>
                </div>
            </div>
            <div class="skincare-routine__info-item">
                <h6>How To Use</h6>
                <p>Use the Neck &amp; Décolletage Device on clean, dry skin for 10 minutes, 3-5 times per week. For best results, follow with the All-In-One Serum.</p>
                <hr />
                <h6>When To Use</h6>
                <div class="badges">
                    <div class="e-pill-badge e-pill-badge--sm">
                        <i class="e-icon e-icon-am"></i> AM
                    </div>
                    <span>or</span>
                    <div class="e-pill-badge e-pill-badge--sm">
                        <i class="e-icon e-icon-pm"></i> PM
                    </div>
                </div>
            </div>
            <div class="skincare-routine__info-item">
                <h6>How To Use</h6>
                <p>Once every 2 weeks, use the Micro-Infusion System in place of your nightly routine. Gently stamp across the face, focusing on areas with dark spots and discoloration.</p>
                <hr />
                <h6>When To Use</h6>
                <div class="badges">
                    <div class="e-pill-badge e-pill-badge--sm">
                        <i class="e-icon e-icon-pm"></i> PM
                    </div>
                </div>
            </div>
        </div>
    {{/skincare-routine }}

