{{#> new
    title="Cart"
    body-class="cart"
}}

{{#> section-stack }}
    <!-- CART -->
    <link rel="stylesheet" href="sections/new/cart/cart.css" />
    <section class="cart">
        <div class="container">
            <div class="cart__empty">
                <img src="assets/images/empty-cart.svg" alt="Your cart is currently empty" />
                <h2>Your cart is currently empty</h2>
                <p>Before proceed to checkout you must add some products to your shopping cart. </p>
                <a href="#" class="btn btn--primary">Start Shopping</a>
            </div>
            <div class="cart__content">
                <h2 class="cart__title">Shopping Cart</h2>
                <div class="cart__items">
                    <div class="cart__row">
                        <div class="cart__cell">Product</div>
                        <div class="cart__cell">Quantity</div>
                        <div class="cart__cell">Price</div>
                    </div>
                    <div class="cart__row">
                        <div class="cart__cell">
                            <a href="#">
                                <img src="sections/isolated/cart/images/prd-1.webp" alt="Q-Rejuvalight Pro Facewear" />
                                Q-Rejuvalight Pro Facewear
                            </a>
                        </div>
                        <div class="cart__cell">
                            <div class="e-quantity">
                                <form action="#"><button type="button"><i class="e-icon e-icon-minus"></i></button></form>
                                <input type="number" name="qty" value="1" min="0" />
                                <form action="#"><button type="button"><i class="e-icon e-icon-plus"></i></button></form>
                            </div>
                            <form action="#"><button class="btn-remove" type="button">Remove</button></form>
                        </div>
                        <div class="cart__cell">
                            {{> e-price current="{$dyn}" old="{$dyn}" }}
                        </div>
                    </div>
                    <div class="cart__row">
                        <div class="cart__cell">
                            <a href="#">
                                <img src="sections/isolated/cart/images/prd-2.webp" alt="Q-Rejuvalight Pro Facewear" />
                                Q-Rejuvalight Pro Facewear
                            </a>
                        </div>
                        <div class="cart__cell">
                            <div class="e-quantity">
                                <form action="#"><button type="button"><i class="e-icon e-icon-minus"></i></button></form>
                                <input type="number" name="qty" value="1" min="0" />
                                <form action="#"><button type="button"><i class="e-icon e-icon-plus"></i></button></form>
                            </div>
                            <form action="#"><button class="btn-remove" type="button">Remove</button></form>
                        </div>
                        <div class="cart__cell">
                            {{> e-price current="{$dyn}" old="{$dyn}" }}
                        </div>
                    </div>
                </div>
                <div class="cart__footer">
                    <div class="cart-footer">
                        <div class="cart-footer__secure-ship">
                            <img src="sections/global/drawer/images/secure-ship.svg" alt="Secure Ship" />
                            <p>Protect your order from lost, damage and theft + <strong>$4.20</strong></p>
                            <label class="e-switcher">
                                <input type="checkbox" name="insurance" />
                                <span></span>
                            </label>
                        </div>
                        <ul class="cart-footer__summary">
                            <li>
                                <div><div class="e-pill-save">Exclusive savings</div></div>
                                <div class="e-price e-price--highlight">
                                    <div class="e-price__main">
                                        <div class="e-price__current">$187</div>
                                    </div>
                                </div>
                            </li>
                            <li>
                                <div>Savings:</div>
                                <div class="e-price e-price--profit">
                                    <div class="e-price__main">
                                        <div class="e-price__current">$87</div>
                                    </div>
                                </div>
                            </li>
                            <li>
                                <div>Shipping:</div>
                                <div class="e-price">
                                    <div class="e-price__main">
                                        <div class="e-price__current">Free</div>
                                    </div>
                                </div>
                            </li>
                            <li>
                                <div>Subtotal:</div>
                                <div class="e-price">
                                    <div class="e-price__main">
                                        <div class="e-price__old">$375</div>
                                        <div class="e-price__current">$188</div>
                                    </div>
                                </div>
                            </li>
                        </ul>
                        <div class="cart-footer__checkout">
                            <button class="btn btn--primary">
                                Checkout
                                <i class="e-icon e-icon-lock"></i>
                            </button>
                            <p>
                                <i class="e-icon e-icon-guarantee"></i>
                                Backed by our 30-Day Money-Back Guarantee
                            </p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
    <!-- CART END -->

{{/section-stack }}

{{/new }}
