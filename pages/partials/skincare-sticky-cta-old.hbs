<!-- Sticky CTA start -->
<link rel="stylesheet" href="sections/isolated/sticky-cta/skincare-sticky-cta.css" />
<div id="sticky_cta_cart" class="qure__sticky-atc skincare_plan_cta">
  <div class="container-fluid px-0">
    <div class="accordion accordion-flush tp-product-accordion border-0" id="tp-product-qure">
      <div class="accordion-item qure__accordion-item border-0">
        <button class="accordion-button qure__accordion-header collapsed border-0" type="button"
          data-bs-toggle="collapse" data-bs-target="#key-benefits" aria-expanded="false"
          aria-controls="key-benefits">
          Bundle & Save up to 30%
        </button>
        <div id="key-benefits" class="accordion-collapse qure__accordion-content collapse"
          data-bs-parent="#tp-product-qure">
          <div class="accordion-body px-16 px-md-60">
            <div class="d-flex flex-column flex-lg-row justify-content-between align-items-center gap-4">

              <!-- Bundle progress -->
              <div class="bundle-progress">
                <!-- Product 1 -->
                <div class="bundle-item" data-step="1">
                  <div class="discount-box">15% <br> OFF</div>
                  <div class="item-box d-none">
                    <img src="https://via.placeholder.com/100" alt="Product 1">
                  </div>
                </div>

                <!-- Product 2 -->
                <div class="bundle-item" data-step="2">
                  <div class="discount-box">20% <br> OFF</div>
                  <div class="item-box d-none">
                    <img src="https://via.placeholder.com/100" alt="Product 2">
                  </div>
                </div>

                <!-- Discount 25% -->
                <div class="bundle-item" data-step="3">
                  <div class="discount-box">25% <br> OFF</div>
                  <div class="item-box d-none">
                    <img src="https://via.placeholder.com/100" alt="Product 3">
                  </div>
                </div>

                <!-- Discount 30% -->
                <div class="bundle-item" data-step="4">
                  <div class="discount-box">30% <br> OFF</div>
                  <div class="item-box d-none">
                    <img src="https://via.placeholder.com/100" alt="Product 4">
                  </div>
                </div>

                <!-- Progress Line -->
                <div class="progress-line">
                  <div class="progress-fill"></div>
                </div>
              </div>

              <!-- Subtotal -->
              <div class="d-flex subtotal_cta gap-3">
                <p>Subtotal:</p>
                <p class="compare_price">$528.00</p>
                <p class="discounted_price">$422.40</p>
              </div>

              <!-- Button -->
              <div class="btn_wrap">
                <button class="btn">Add an item to unlock savings!</button>
              </div>

            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<!-- JS Loader -->
<script>
  document.addEventListener("DOMContentLoaded", function () {
    loadScriptOnce('skincare-sticky-cta', 'assets/js/skincare-sticky-cta.js');
