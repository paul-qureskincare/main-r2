    {{#> skincare-lifestyle
        title="Skincare is a lifestyle"
        text="Caring for your skin goes beyond the products you use. It’s about adopting habits that support your skin’s health every day. Our dermatologists recommend these expert tips to help you reach your skin goals even faster."
    }}
        <picture class="show">
            <img src="sections/isolated/skincare-lifestyle/images/sk_life_1_acne.webp" alt="Cleanse and exfoliate regularly" />
        </picture>
        <picture>
            <img src="sections/isolated/skincare-lifestyle/images/sk_life_2_acne.webp" alt="Keep your tools and surfaces clean" />
        </picture>
        <picture>
            <img src="sections/isolated/skincare-lifestyle/images/sk_life_3_acne.webp" alt="Change your pillowcase every 2-3 days" />
        </picture>
        <ul>
            <li>
                <button class="active" type="button">1</button>
                <h6>Cleanse and exfoliate regularly</h6>
                <p>Daily cleansing removes pore-clogging bacteria, while regular exfoliation with Beta-Hydroxy Acid (BHA) helps reduce irritation and prevents future breakouts</p>
                <img src="sections/isolated/skincare-lifestyle/images/sk_life_1_acne.webp" alt="Cleanse and exfoliate regularly" />
            </li>
            <li>
                <button type="button">2</button>
                <h6>Keep your tools and surfaces clean</h6>
                <p>Makeup tools and your phone collect bacteria that clog pores. Cleaning them regularly can reduce the chances of breakouts and help keep your skin fresh.</p>
                <img src="sections/isolated/skincare-lifestyle/images/sk_life_2_acne.webp" alt="Keep your tools and surfaces clean" />
            </li>
            <li>
                <button type="button">3</button>
                <h6>Change your pillowcase every 2-3 days</h6>
                <p>To prevent buildup of oil, sweat, and bacteria that can lead to breakouts and irritation.</p>
                <img src="sections/isolated/skincare-lifestyle/images/sk_life_3_acne.webp" alt="Change your pillowcase every 2-3 days" />
            </li>
        </ul>
    {{/skincare-lifestyle }}

    {{#> skin-deserves
        title="Your skin deserves Qure"
        text="Skincare isn’t a numbers game. More products won’t help if your skin can’t use them effectively. Qure gives you the right treatment, in the right way, for results you can actually see."
    }}
        <table>
            <tr>
                <th>{{> e-icon icon="qure"}}</th>
                <th>&nbsp;</th>
                <th>&nbsp;</th>
                <th>Other Products</th>
            </tr>
            <tr>
                <td>Effective and proven formulas</td>
                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
                <td>Show minimal improvement or change</td>
            </tr>
            <tr>
                <td>Penetrates deep for better results</td>
                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
                <td>Topical products stay on the surface</td>
            </tr>
            <tr>
                <td>Gentle on skin with no downtime</td>
                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
                <td>Can cause irritation and peeling</td>
            </tr>
            <tr>
                <td>Safe to use at-home</td>
                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
                <td>Often requires clinic visits and downtime</td>
            </tr>
            <tr>
                <td>Backed by dermatologists</td>
                <td>{{> e-icon icon="checkmark-fill"}}</td>
                <td>{{> e-icon icon="cross-fill"}}</td>
                <td>Not always tested or recommended</td>
            </tr>
        </table>
    {{/skin-deserves }}

    {{#> bundle-routine
        title="Bundle your new routine"
        text="Mix and match our targeted treatments to create a high-performance routine that fits your skin goals."
    }}
        <ul>
            {{#parseJson
                '[
                    {
                        "image": "sections/isolated/bundle-routine/images/bndl_routine_1.webp",
                        "name": "Q-Rejuvalight Pro Facewear",
                        "added": true
                    },
                    {
                        "image": "sections/isolated/bundle-routine/images/shower_routine.webp",
                        "name": "Shower Filter"
                    },
                    {
                        "image": "sections/isolated/bundle-routine/images/bndl_routine_3.webp",
                        "name": "All-In-One Face Serum"
                    },
                    {
                        "image": "sections/isolated/bundle-routine/images/derm_routine.webp",
                        "name": "Dermal Mist"
                    }
                ]'
            }}
                <li>
                    <a href="#"><img src="{{ image }}" alt="{{ name }}" /></a>
                    <p><a href="#">{{ name }}</a></p>
                    {{#if added }}
                        <button class="btn btn--primary btn--added" type="button">Added</button>
                    {{ else}}
                        <button class="btn btn--primary" type="button">Add to Bundle</button>
                    {{/if }}
                </li>
            {{/parseJson}}
        </ul>
    {{/bundle-routine }}

    {{> skincare-sticky-cta-old }}
{{/section-stack }}

{{/new }}
