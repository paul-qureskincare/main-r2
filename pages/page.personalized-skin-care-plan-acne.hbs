{{#> new
    title="Skincare Acne"
    body-class="page.personalized-skin-care-plan-acne"
}}

{{#> section-stack }}
    {{#> base-section
        title="Your results are in."
        picture="sections/global/banner-with-text/images/transform_aging_acne.webp"
        button="Shop & Save 25%"
    }}
        <h6>Let’s transform your breakouts!</h6>
        <br />
        <p>We know how confidence destroying acne can be, but with the right plan in place, you're just a few steps away from clearer, happier, healthier-looking skin. We've created a personalized routine just for you to help tackle acne and keep your skin radiant and glowing.</p>
    {{/base-section }}

    {{#> we-suggest
        title="Based on your goals, we suggest:"
    }}
        <div class="we-suggest__list">
            {{#> c-suggest-card
                title="Q-Rejuvalight Pro Facewear"
                image="sections/isolated/skincare-plan/images/q-rej-product.webp"
                image-hover="/sections/isolated/skincare-plan/images/hov_img_1.webp"
                results="sections/isolated/skincare-plan/images/transform_aging_97.webp"
                desc="A hands-free LED light therapy mask that uses clinically proven wavelengths to target multiple skin concerns."
                video="jwKN4SH4yz8"
                quot-strong="I noticed results straight away!"
                quot-small="Now I can’t go a day without the Q-Rejuvalight Mask."
                added=true
                id="suggestCardRejuvalight"
            }}
                <ul class="c-marked-list">
                    <li>FDA-cleared device designed to treat wrinkles and mild-to-moderate inflammatory acne.</li>
                    <li>Customizable treatment on 5 facial areas for your specific skin concerns.</li>
                    <li>Quick 3 minute, wireless daily treatments with convenient hands-free operation.</li>
                </ul>
            {{/c-suggest-card }}
            {{#> c-suggest-card
                title="Shower Filter"
                image="sections/isolated/skincare-plan/images/shower_filter_acne.webp"
                image-hover="/sections/isolated/skincare-plan/images/hov_img_2_acne.webp"
                results="sections/isolated/skincare-plan/images/shwr_res_acne.webp"
                desc="Healthy skin starts with your water. The Qure Shower Filter helps reduce harmful impurities that damage skin and hair."
                video="Jqw2lZirHz4"
                quot-strong="This filter makes a huge difference"
                quot-small="in removing impurities that irritate the skin."
                doctor-review=true
                id="suggestCardShowerFilter"
            }}
                <ul class="c-marked-list">
                    <li>Reduces chlorine, heavy metals, and other impurities that can disrupt your skin barrier.</li>
                    <li>Clinically proven to increase skin and scalp moisture after just 8 weeks.</li>
                    <li>Available in three colors, with an easy-to-install design.</li>
                </ul>
            {{/c-suggest-card }}
            {{#> c-suggest-card
                title="All-In-One Face Serum"
                image="sections/isolated/skincare-plan/images/all-in-prod.webp"
                image-hover="/sections/isolated/skincare-plan/images/hov_img_3.webp"
                results="sections/isolated/skincare-plan/images/all_in_res_acne.webp"
                desc="A multi-tasking formula designed to hydrate, brighten, and strengthen skin barrier in one step."
                video="PJt57LcFEQk"
                quot-strong="This product is a keeper."
                quot-small="My skin looks better than ever after just 2 weeks."
                id="suggestCardSerum"
            }}
                <ul class="c-marked-list">
                    <li>Helps improve skin texture and reduce the appearance of hyperpigmentation.</li>
                    <li>Lightweight, non-sticky formula that absorbs quickly and layers well.</li>
                    <li>Formulated with soothing botanicals to calm and comfort the skin.</li>
                </ul>
            {{/c-suggest-card }}
            {{#> c-suggest-card
                title="Dermal Mist"
                image="sections/isolated/skincare-plan/images/dermal_mist_acne.webp"
                image-hover="/sections/isolated/skincare-plan/images/hov_img_4_acne.webp"
                desc="A refreshing facial spray that calms irritation, purifies the skin, and accelerates skin healing. Ideal for daily use."
                video="Ecw9o0bM6Gc"
                quot-strong="I take this with me everywhere"
                quot-small="it keeps my skin calm and hydrated all day!"
                id="suggestCardDermalMist"
            }}
                <ul class="c-marked-list">
                    <li>Gently purifies your skin, reducing breakout-causing bacteria without stripping or drying it out.</li>
                    <li>Helps calm inflammation and keeps your skin refreshed throughout the day.</li>
                    <li>Versatile and safe to use on your face, body and devices.</li>
                </ul>
            {{/c-suggest-card }}
        </div>
        <form class="we-suggest__button" action="#">
            <button class="btn btn--primary" type="button">Add Complete Bundle To Cart</button>
        </form>
    {{/we-suggest }}

    {{> logos-marquee }}

    {{#> skincare-routine
        title="Meet your new skincare routine"
    }}
        <div class="skincare-routine__media">
            <div class="skincare-routine__media-item show">
                <img src="sections/isolated/skincare-routine/images/morning_routine.webp" alt="Meet your new skincare routine" />
            </div>
            <div class="skincare-routine__media-item">
                {{#> c-wistia-embed-video
                    classes=""
                    id="klt401yhji"
                    alt="Meet your new skincare routine"
                    inline=true
                }}
                {{/c-wistia-embed-video}}
            </div>
        </div>
        <ul class="skincare-routine__switcher">
            <li><button type="button" class="active">Morning</button></li>
            <li><button type="button">Morning</button></li>
        </ul>
        <div class="skincare-routine__info">
            <div class="skincare-routine__info-item show">
                <h6>How To Use</h6>
                <p>After cleansing, mist your skin with the Dermal Mist, then (optional) apply the All-In-One Face Serum to damp skin for optimal absorption.</p>
                <hr />
                <h6>Benefits</h6>
                <ul>
                    <li>Hydrated, balanced skin all day</li>
                    <li>Brightened tone and lightweight moisture</li>
                    <li>Skin stays calm even post-shower</li>
                </ul>
            </div>
            <div class="skincare-routine__info-item">
                <h6>How To Use</h6>
                <p>Cleanse and dry your skin. Use your Q-Rejuvalight Pro on Anti-Breakout Mode for a full 3-minute session. Follow with a refreshing spritz of the Dermal Mist to soothe and lock in moisture.</p>
                <hr />
                <h6>When To Use</h6>
                <ul>
                    <li>Boosts skin’s recover overnight</li>
                    <li>Targets active acne while reduces future breakouts</li>
                    <li>Lightweight routine, no heavy creams needed</li>
                </ul>
            </div>
        </div>
    {{/skincare-routine }}

