<!-- HERO PRODUCT -->
{{#unless page-css }}
<link rel="stylesheet" href="sections/new/hero-product/hero-product.css" />
{{/unless}}
<section class="hero-product {{ classes }}" id="hero-product">
    <div class="hero-product__container container">
        {{> @partial-block}}
    </div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('swiper', 'assets/js-new/swiper.js');
        loadScriptOnce('countdown', 'assets/js-new/countdown.js');
        loadScriptOnce('youtube-popup', 'assets/js-new/yt-popup.js');
        loadScriptOnce('wistia-popup', 'assets/js-new/wistia-popup.js');
        loadScriptOnce('wistia-script', 'https://fast.wistia.com/assets/external/E-v1.js');
        loadScriptOnce('gallery-sticky-video', 'assets/js-new/gallery-sticky-video.js');
        loadScriptOnce('dialog', 'assets/js-new/dialog.js');
    });
</script>
<!-- HERO PRODUCT END -->
