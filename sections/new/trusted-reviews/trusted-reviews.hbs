<!-- TRUSTED REVIEWS -->
{{#unless page-css }}
<link rel="stylesheet" href="sections/new/trusted-reviews/trusted-reviews.css" />
{{/unless}}
<section class="trusted-reviews {{ classes }}" {{#if id }}id="{{ id }}"{{/if}}>
    <div class="container">
        <h2>{{ title }}</h2>
        <div
            class="c-swiper"
            data-swiper='{
                "slidesPerView": 1.1,
                "spaceBetween": 16,
                "loop": false,
                "pagination": {
                    "el": ".c-swiper-pagination",
                    "type": "custom"
                },
                "navigation": {
                    "prevEl": ".c-swiper-button-prev",
                    "nextEl": ".c-swiper-button-next"
                },
                "breakpoints": {
                    "768": {
                        "slidesPerView": 2,
                        "spaceBetween": 24
                    },
                    "992": {
                        "slidesPerView": 3
                    }
                }
            }'
        >
            <div class="swiper-wrapper">
                {{> @partial-block }}
            </div>
            <div class="c-swiper-nav">
                <button class="c-swiper-button-prev"></button>
                <div class="c-swiper-pagination"></div>
                <button class="c-swiper-button-next"></button>
            </div>
        </div>
        {{#if button }}
            <button class="btn btn--primary" type="button">{{ button }}</button>
        {{/if}}
    </div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('swiper', 'assets/js-new/swiper.js');
    });
</script>
<!-- TRUSTED REVIEWS END -->
