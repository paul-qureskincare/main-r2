<!-- LEARN MORE -->
{{#unless page-css }}
<link rel="stylesheet" href="sections/new/learn-more/learn-more.css" />
{{/unless}}
<section class="learn-more {{ classes }}">
    <div class="container">
        <h2>{{ title }}</h2>
        <div class="c-swiper c-swiper-thumbs"
            data-swiper='{
                "slidesPerView": 1,
                "spaceBetween": 16,
                "watchSlidesProgress": true,
                "allowTouchMove": false,
                "breakpoints": {
                    "768": {
                        "slidesPerView": 4,
                        "spaceBetween": 20,
                        "centeredSlides": false
                    }
                }
            }'
        >
            <div class="swiper-wrapper">
                <div class="swiper-slide">
                    <div class="learn-more__tile">
                        <img src="sections/isolated/board-advisory/images/led_mask.webp" alt="LED Therapy" />
                        <div>
                            <h6>LED Therapy</h6>
                            <p>Targeted red light therapy to firm and smooth skin.</p>
                        </div>
                    </div>
                </div>
                <div class="swiper-slide">
                    <div class="learn-more__tile">
                        <img src="sections/isolated/board-advisory/images/micro-infusion.webp" alt="Micro-Infusion" />
                        <div>
                            <h6>Micro-Infusion</h6>
                            <p>Smooth fine lines, hydrate, and firm skin.</p>
                        </div>
                    </div>
                </div>
                <div class="swiper-slide">
                    <div class="learn-more__tile">
                        <img src="sections/isolated/board-advisory/images/topical.webp" alt="Topical Treatments" />
                        <div>
                            <h6>Topical Treatments</h6>
                            <p>Target acne and dehydration with clinical solutions.</p>
                        </div>
                    </div>
                </div>
                <div class="swiper-slide">
                    <div class="learn-more__tile">
                        <img src="sections/isolated/board-advisory/images/filters.webp" alt="Filters" />
                        <div>
                            <h6>Filters</h6>
                            <p>Remove chlorine, bacteria, and metals at the source.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div
            class="c-swiper"
            data-swiper-thumbs=".learn-more .c-swiper-thumbs"
            data-swiper='{
                "slidesPerView": 1,
                "spaceBetween": 16,
                "pagination": {
                    "el": ".c-swiper-pagination",
                    "type": "custom"
                },
                "navigation": {
                    "prevEl": ".c-swiper-button-prev",
                    "nextEl": ".c-swiper-button-next"
                }
            }'
        >
            <div class="swiper-wrapper">
                <div class="swiper-slide">
                    <div class="learn-more__content">
                        <article class="learn-more__content-article">
                            <h5>Treat skin concerns from the inside out</h5>
                            <p>Clinically proven wavelengths penetrate deep into the skin, energizing cells to boost collagen production and reduce wrinkles, dark spots, and redness.</p>
                            <ul>
                                <li>Covers hard-to-treat areas like the jawline, neck, and chest for all-over results.</li>
                                <li>Boosts collagen production to firm and smooth the skin over time.</li>
                                <li>Reduces the appearance of fine lines, wrinkles, and uneven tone.</li>
                                <li>Hands-free treatment you can use in just a few minutes.</li>
                            </ul>
                        </article>
                        <ul class="learn-more__content-list">
                            <li>
                                <a href="#">
                                    <img src="sections/isolated/board-advisory/images/q-rejuvalight-mask.webp" alt="Q-Rejuvalight Pro LED Mask" />
                                    <strong>Q-Rejuvalight Pro LED Mask</strong>
                                    <small>Shop Now</small>
                                </a>
                            </li>
                            <li>
                                <a href="#">
                                    <img src="sections/isolated/board-advisory/images/neck-led-device.webp" alt="Neck & Décolletage LED Device" />
                                    <strong>Neck &amp; Décolletage LED Device</strong>
                                    <small>Shop Now</small>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="swiper-slide">
                    <div class="learn-more__content">
                        <article class="learn-more__content-article">
                            <h5>Precision skincare that works below the surface</h5>
                            <p>Infuse active ingredients beneath the surface of your skin for maximum efficacy, evening out texture, softening fine lines, and promoting a youthful appearance.</p>
                            <ul>
                                <li>Improves overall glow, firmness, and bounce.</li>
                                <li>Helps fade dark spots and brighten tone.</li>
                                <li>Smooths fine lines and softens wrinkles.</li>
                                <li>Clinically backed and easy to use at home.</li>
                            </ul>
                        </article>
                        <ul class="learn-more__content-list">
                            <li>
                                <a href="#">
                                    <img src="sections/isolated/board-advisory/images/micro-infusion-treatment.webp" alt="Micro-Infusion Treatment" />
                                    <strong>Micro-Infusion Treatment</strong>
                                    <small>Shop Now</small>
                                </a>
                            </li>
                            <li>
                                <a href="#">
                                    <img src="sections/isolated/board-advisory/images/micro-infusion-targeted-patches.webp" alt="Micro-Infusion Targeted Patches" />
                                    <strong>Micro-Infusion Targeted Patches</strong>
                                    <small>Shop Now</small>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="swiper-slide">
                    <div class="learn-more__content">
                        <article class="learn-more__content-article">
                            <h5>Hydrate and strengthen your skin barrier</h5>
                            <p>Lightweight formulas to balance, calm, and support recovery after treatments.</p>
                            <ul>
                                <li>Improves skin texture by reducing roughness and dehydration lines.</li>
                                <li>Delivers long-lasting moisture to keep skin soft and plump.</li>
                                <li>Restores glow to dull or dehydrated skin.</li>
                                <li>Gentle on sensitive and reactive skin.</li>
                            </ul>
                        </article>
                        <ul class="learn-more__content-list">
                            <li>
                                <a href="#">
                                    <img src="sections/isolated/board-advisory/images/all-in-one-serum.webp" alt="All-In-One Serum" />
                                    <strong>All-In-One Serum</strong>
                                    <small>Shop Now</small>
                                </a>
                            </li>
                            <li>
                                <a href="#">
                                    <img src="sections/isolated/board-advisory/images/dermal-mist.webp" alt="Dermal Mist" />
                                    <strong>Dermal Mist</strong>
                                    <small>Shop Now</small>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
                <div class="swiper-slide">
                    <div class="learn-more__content">
                        <article class="learn-more__content-article">
                            <h5>Healthier, calmer skin every time you wash</h5>
                            <p>Remove chlorine, heavy metals, and harmful bacteria from your tap water, to help protect your skin against premature aging, dryness, and irritation.</p>
                            <ul>
                                <li>Supports a healthier skin barrier by preventing exposure to harsh water.</li>
                                <li>Improves the effectiveness of your skincare products.</li>
                                <li>Helps reduce skin irritation, dryness, and sensitivity.</li>
                            </ul>
                        </article>
                        <ul class="learn-more__content-list">
                            <li>
                                <a href="#">
                                    <img src="sections/isolated/board-advisory/images/shower-filter.webp" alt="Shower Filter" />
                                    <strong>Shower Filter</strong>
                                    <small>Shop Now</small>
                                </a>
                            </li>
                            <li>
                                <a href="#">
                                    <img src="sections/isolated/board-advisory/images/water-filter.webp" alt="Water Filter" />
                                    <strong>Water Filter</strong>
                                    <small>Shop Now</small>
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
            <div class="c-swiper-nav">
                <button class="c-swiper-button-prev"></button>
                <div class="c-swiper-pagination"></div>
                <button class="c-swiper-button-next"></button>
            </div>
        </div>
    </div>
</section>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        loadScriptOnce('swiper', 'assets/js-new/swiper.js');
    });
</script>
<!-- LEARN MORE END -->
